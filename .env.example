# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cross_sell
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/cross_sell

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-secret-key-change-in-production-min-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MODEL_NAME=nba_propensity_model
MODEL_VERSION=latest

# API
API_V1_PREFIX=/api/v1
PROJECT_NAME=NBA Cross-Sell Engine
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501