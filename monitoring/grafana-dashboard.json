{
  "dashboard": {
    "title": "CrossSell IQ - Production Dashboard",
    "uid": "crosssell-iq-main",
    "panels": [
      {
        "title": "Request Rate",
        "targets": [{"expr": "rate(http_requests_total[5m])"}],
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8}
      },
      {
        "title": "P95 Latency",
        "targets": [{"expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))"}],
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}
      },
      {
        "title": "Predictions per Minute",
        "targets": [{"expr": "rate(predictions_total[1m])"}],
        "gridPos": {"x": 0, "y": 8, "w": 8, "h": 8}
      },
      {
        "title": "Model Drift Score",
        "targets": [{"expr": "model_prediction_drift"}],
        "gridPos": {"x": 8, "y": 8, "w": 8, "h": 8}
      },
      {
        "title": "Active Agents",
        "targets": [{"expr": "active_agents"}],
        "gridPos": {"x": 16, "y": 8, "w": 8, "h": 8}
      },
      {
        "title": "Propensity Distribution",
        "targets": [{"expr": "rate(propensity_score_distribution_bucket[5m])"}],
        "gridPos": {"x": 0, "y": 16, "w": 24, "h": 8}
      }
    ]
  }
}
